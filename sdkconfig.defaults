# TaskMaster-C3 — ESP-IDF default config (baked baseline; tweak via `menuconfig`)

# --- Flash / partitions ---
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

# --- OTA (§9, step 7): dual-slot update + rollback. A freshly-OTA'd image boots as
# pending-verify; main calls esp_ota_mark_app_valid_cancel_rollback() once it's healthy,
# else the bootloader reverts to the previous slot on the next reboot. ---
CONFIG_BOOTLOADER_APP_ROLLBACK_ENABLE=y
# Allow a plain http:// fw_url so the device can OTA from a local LAN server
# (§6D zero-hosting: tools/ota_serve.py). HTTPS URLs still verify via the cert bundle.
CONFIG_ESP_HTTPS_OTA_ALLOW_HTTP=y

# --- FreeRTOS: 1kHz tick so the 1ms input poll task is responsive (PLAN §4.6) ---
CONFIG_FREERTOS_HZ=1000

# --- HTTP server: room for the provisioning form POST later ---
CONFIG_HTTPD_MAX_REQ_HDR_LEN=1024
CONFIG_HTTPD_MAX_URI_LEN=512

# --- Logging ---
CONFIG_LOG_DEFAULT_LEVEL_INFO=y

# --- LVGL (UI foundation, §8.5) ---
# 1-bit pixel font: crisp on the mono OLED (anti-aliased fonts dither to "dots").
# UNSCII also has lowercase, replacing the bring-up 5x7 uppercase-only font.
CONFIG_LV_FONT_UNSCII_8=y
CONFIG_LV_FONT_DEFAULT_UNSCII_8=y

# --- §6A memory-safety / leak discipline ---
# Stack-overflow trap is cheap — keep it on in every build.
CONFIG_FREERTOS_WATCHPOINT_END_OF_STACK=y
# Heap leak/overflow detection has a runtime cost: enable in debug builds via
# `idf.py menuconfig` (Component config → Heap memory debugging) when running the
# launch→Home→relaunch leak cycle (PLAN §6A.3/§6A.4). Left off in the default build:
#   CONFIG_HEAP_POISONING_COMPREHENSIVE=y
#   CONFIG_HEAP_TASK_TRACKING=y

# --- HTTPS cert bundle (direct Todoist, §8) ---
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE=y
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE_DEFAULT_FULL=y
